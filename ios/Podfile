platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

# CocoaPods/Xcode can emit broken relative paths to ~/.pub-cache when the project
# lives deep in the filesystem (e.g. OneDrive). They resolve to /.pub-cache/… and
# fail with lstat. Rewrite to ios/.symlinks/plugins/… which always exists.
def fix_pods_pub_cache_paths!(installer)
  ios_dir = File.dirname(__FILE__)
  pub_cache_re = %r{(?:\.\./)*\.pub-cache/hosted/pub\.dev/([a-zA-Z0-9_]+)-[\d.+\w-]+/(.*)\z}

  installer.pods_project.objects.each do |obj|
    next unless obj.respond_to?(:path) && obj.path&.include?('.pub-cache/hosted/pub.dev/')

    match = obj.path.match(pub_cache_re)
    next unless match

    abs_path = File.expand_path(
      File.join('.symlinks/plugins', match[1], match[2]),
      ios_dir
    )
    next unless File.exist?(abs_path)

    obj.path = abs_path
    obj.source_tree = '<absolute>' if obj.respond_to?(:source_tree=)
  end
  installer.pods_project.save
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # permission_handler (Apple): Ohne dieses Makro wird Standort-Code nicht eingebunden -
      # dann fehlt u. a. oft der Standort-Eintrag unter Einstellungen > Ihdina.
      # Siehe https://pub.dev/packages/permission_handler (iOS Setup)
      defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
      defs = defs.is_a?(Array) ? defs : defs.split(' ')
      defs << 'PERMISSION_LOCATION=1' unless defs.any? { |d| d.to_s.include?('PERMISSION_LOCATION') }
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs
    end
  end
  fix_pods_pub_cache_paths!(installer)
end
