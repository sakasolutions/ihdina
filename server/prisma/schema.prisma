generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(cuid())
  installId   String    @unique
  displayName String?   @map("display_name")
  isPro       Boolean   @default(false)
  /// Entwickler-/Testnutzer — standardmäßig aus Produkt-KPIs ausschließen.
  isInternal  Boolean   @default(false)
  /// Erstes gespeichertes AppOpenEvent (Kohortenbeginn); null wenn nie geöffnet.
  firstAppOpenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime?

  /// RevenueCat $RCAnonymousID / custom app user id (often mirrors installId in V1).
  revenueCatAppUserId   String?   @unique
  proExpiresAt          DateTime?
  entitlementSource     String?
  lastRevenueCatEventAt DateTime?

  dailyUsages    DailyExplanationUsage[]
  followUpUsages FollowUpUsage[]
  aiRequestLogs  AiRequestLog[]
  appFeedbacks   AppFeedback[]
  appOpenEvents  AppOpenEvent[]
  productEvents  ProductEvent[]

  @@index([firstAppOpenAt, isInternal])
}

/// Client-Produktanalytics (kein app_opened — siehe AppOpenEvent).
model ProductEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique
  eventVersion    Int
  eventName       String
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  installId       String
  sessionId       String?
  occurredAt      DateTime
  receivedAt      DateTime @default(now())
  platform        String?
  appVersion      String?
  buildNumber     String?
  isProSnapshot   Boolean?
  source          String?
  surahNumber     Int?
  ayahNumber      Int?
  properties      Json?
  createdAt       DateTime @default(now())

  @@index([userId, occurredAt])
  @@index([installId, occurredAt])
  @@index([eventName, occurredAt])
  @@index([occurredAt])
  @@index([sessionId])
  @@index([userId, eventName, occurredAt])
}

/// Idempotente Speicherung eingehender RevenueCat-Webhooks (Audit + Duplikat-Schutz).
model RevenueCatWebhookEvent {
  id                 Int      @id @default(autoincrement())
  eventId            String   @unique
  eventType          String
  appUserId          String?
  originalAppUserId  String?
  transferredTo      String?
  transferredFrom    String?
  rawJson            String   @db.Text
  createdAt          DateTime @default(now())
}

/// Tracks non-daily “extra” explanations per calendar day (UTC) for free users.
model DailyExplanationUsage {
  id              String @id @default(cuid())
  userId          String
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageDate       String
  extraCount      Int    @default(0)
  dailyVerseCount Int    @default(0)
  takeawayCount   Int    @default(0)
  reflectionCount Int    @default(0)
  reflectionExpandCount Int @default(0)
  followUpCount   Int    @default(0) @map("follow_up_count")

  @@unique([userId, usageDate])
  @@index([userId])
}

/// Successful follow-up count per verse (Pro); max 3 enforced in app logic.
model FollowUpUsage {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  surahName  String
  ayahNumber Int
  count      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, surahName, ayahNumber])
  @@index([userId])
}

model AiRequestLog {
  id               String   @id @default(cuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  endpoint         String
  status           String
  errorCode        String?
  model            String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  latencyMs        Int?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([errorCode, createdAt])
  @@index([userId, endpoint, createdAt])
}

/// In-App-Feedback (Rating + optionaler Text), verknüpft mit installId / optional User.
model AppFeedback {
  id        String   @id @default(cuid())
  installId String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  rating    Int?
  comment   String?  @db.Text
  context   String?  @db.Text
  screen    String?
  createdAt DateTime @default(now())

  @@index([installId])
  @@index([createdAt])
  @@index([createdAt, screen])
}

/// App-Foreground/Start — ein Eintrag pro gemeldeter Öffnung (kein Feature-Bezug).
model AppOpenEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}
